{
  "name": "worduel",
  "version": "0.1.3",
  "description": "Play Wordle inside Claude Code",
  "type": "module",
  "license": "MIT",
  "bin": {
    "worduel": "./dist/index.js"
  },
  "keywords": [
    "wordle",
    "mcp",
    "claude",
    "claude-code",
    "game",
    "terminal",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wtaisen/worduel"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.8",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "data"
  ]
}
